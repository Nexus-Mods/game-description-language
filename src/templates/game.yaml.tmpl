gdl: 1
version: 0.0.1

game:
  id: {{GAME_ID}}
  name: {{GAME_NAME}}
  executable: {{GAME_ID}}.exe
  requiredFiles:
    - {{GAME_ID}}.exe
  nexusDomain: {{GAME_ID}}   # the nexusmods.com/<domain> slug (often the same as id)
  # logo: gameart.webp       # add a 16:9 gameart.webp beside this file, then uncomment

stores:
  steam: 0    # replace with the game's Steam app id

modTypes: []     # add one entry per mod type the game supports

installers: []   # add installer rules

# Releasing requires a `nexus` block with real positive ids; GDL rejects 0/placeholder
# values at build time, so add it once the extension's Nexus page exists:
#
# nexus:
#   modId: 0          # the mod-page id from nexusmods.com/site/mods/<id>
#   fileGroupId: 0    # the file-group id Nexus shows on the upload page
#   displayName: {{GAME_NAME}} Support for Vortex

tests:
  corpus: off
  cases: []
