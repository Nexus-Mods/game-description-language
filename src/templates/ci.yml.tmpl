name: CI

on:
  push:
    branches: [main]
    tags: ['v*']
  pull_request:
    branches: [main]

jobs:
  test:
    uses: ./gdl/.github/workflows/test.yml@main
    secrets: inherit

  release:
    if: startsWith(github.ref, 'refs/tags/v')
    needs: test
    uses: ./gdl/.github/workflows/release.yml@main
    secrets: inherit
