{
  "name": "game-description-language",
  "version": "0.0.1",
  "description": "Build-time toolchain for Vortex game extensions",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.0.9",
  "engines": { "node": ">=22" },
  "bin": { "gdl": "./dist/cli.js" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "webpack": "^5.91.0",
    "ts-loader": "^9.5.1",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.5",
    "vitest": "^3.0.0"
  }
}
